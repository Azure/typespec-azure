{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "lib/**",
        "tsconfig*.json",
        "package.json",
        ".scripts/**",
        "astro.config.mjs"
      ],
      "outputs": ["dist/**"],
      "env": ["TYPESPEC_WEBSITE_BASE_PATH", "TYPESPEC_SKIP_WEBSITE_BUILD"]
    }
  }
}
