{
  "name": "@azure-tools/typespec-benchmark",
  "private": true,
  "version": "1.0.0",
  "author": "Microsoft Corporation",
  "description": "Benchmark tooling for TypeSpec Azure compilation performance",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "typespec-benchmark": "./dist/src/cli.js"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json --watch",
    "bench": "node ./dist/src/cli.js run",
    "bench:compare": "node ./dist/src/cli.js compare"
  },
  "dependencies": {
    "@typespec/compiler": "workspace:^",
    "@typespec/http": "workspace:^",
    "@typespec/rest": "workspace:^",
    "@typespec/openapi": "workspace:^",
    "@typespec/openapi3": "workspace:^",
    "@typespec/versioning": "workspace:^",
    "@azure-tools/typespec-azure-core": "workspace:^",
    "@azure-tools/typespec-azure-resource-manager": "workspace:^",
    "@azure-tools/typespec-azure-rulesets": "workspace:^",
    "@azure-tools/typespec-autorest": "workspace:^",
    "@azure-tools/typespec-client-generator-core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
