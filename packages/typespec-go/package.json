{
  "name": "@azure-tools/typespec-go",
  "version": "0.14.2",
  "author": "Microsoft Corporation",
  "description": "TypeSpec emitter for Go SDKs",
  "homepage": "https://azure.github.io/typespec-azure",
  "readme": "https://github.com/Azure/typespec-azure/blob/main/packages/typespec-go/README.md",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Azure/typespec-azure.git"
  },
  "bugs": {
    "url": "https://github.com/Azure/typespec-azure/issues"
  },
  "keywords": [
    "go",
    "golang",
    "typespec"
  ],
  "type": "module",
  "main": "dist/src/index.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "tspMain": "dist/src/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "rimraf ./dist ./temp ./node_modules",
    "build": "tsc -p .",
    "watch": "tsc -p . --watch",
    "test": "vitest run --pass-with-no-tests",
    "test:ci": "vitest run --pass-with-no-tests --coverage",
    "test:go:e2e": "pnpm spector --start && pnpm go-test && pnpm spector --stop",
    "go-test": "node .scripts/go-test.js",
    "lint:go": "node .scripts/lint-go.js",
    "regenerate": "node .scripts/tspcompile.js",
    "spector": "node .scripts/spector.js",
    "sync-specs": "node .scripts/sync-azure-rest-api-specs.js",
    "regen-docs": "tspd doc . --enable-experimental --output-dir ../../website/src/content/docs/docs/emitters/clients/typespec-go/reference --skip-js"
  },
  "files": [
    "dist/**",
    "!dist/test/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@azure-tools/typespec-client-generator-core": "workspace:^",
    "@typespec/compiler": "workspace:^",
    "@typespec/http": "workspace:^"
  },
  "dependencies": {
    "semver": "catalog:",
    "source-map-support": "catalog:"
  },
  "devDependencies": {
    "@azure-tools/azure-http-specs": "workspace:^",
    "@azure-tools/typespec-autorest": "workspace:^",
    "@azure-tools/typespec-azure-core": "workspace:^",
    "@azure-tools/typespec-azure-resource-manager": "workspace:^",
    "@azure-tools/typespec-azure-rulesets": "workspace:^",
    "@azure-tools/typespec-client-generator-core": "workspace:^",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@typespec/compiler": "workspace:^",
    "@typespec/events": "workspace:^",
    "@typespec/http": "workspace:^",
    "@typespec/http-specs": "workspace:^",
    "@typespec/openapi": "workspace:^",
    "@typespec/rest": "workspace:^",
    "@typespec/spec-api": "workspace:^",
    "@typespec/spector": "workspace:^",
    "@typespec/sse": "workspace:^",
    "@typespec/streams": "workspace:^",
    "@typespec/tspd": "workspace:^",
    "@typespec/versioning": "workspace:^",
    "@typespec/xml": "workspace:^",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
