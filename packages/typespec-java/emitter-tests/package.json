{
  "name": "@azure-tools/typespec-java-tests",
  "version": "0.45.7",
  "type": "module",
  "scripts": {
    "format": "npm run -s prettier -- --write",
    "check-format": "npm run prettier -- --check",
    "prettier": "prettier --config ./.prettierrc.yaml **/*.tsp",
    "regenerate": "pwsh ./Generate.ps1",
    "test:java:e2e": "pwsh ./Spector-Tests.ps1",
    "spector-serve": "tsp-spector serve ./node_modules/@typespec/http-specs/specs ./node_modules/@azure-tools/azure-http-specs/specs --coverageFile ./tsp-spector-coverage-java.json",
    "spector-start": "tsp-spector server start ./node_modules/@typespec/http-specs/specs ./node_modules/@azure-tools/azure-http-specs/specs --coverageFile ./tsp-spector-coverage-java.json",
    "spector-stop": "tsp-spector server stop"
  },
  "dependencies": {
    "@typespec/spec-api": "0.1.0-alpha.15",
    "@typespec/spector": "0.1.0-alpha.26",
    "@typespec/http-specs": "0.1.0-alpha.39",
    "@azure-tools/azure-http-specs": "0.1.0-alpha.43",
    "@azure-tools/typespec-java": "file:../azure-tools-typespec-java-0.45.7.tgz"
  },
  "devDependencies": {
    "@typespec/prettier-plugin-typespec": "^1.13.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier": "^3.8.4"
  },
  "overrides": {
    "@typespec/compiler": "1.14.0",
    "@typespec/http": "1.14.0",
    "@typespec/rest": "0.84.0",
    "@typespec/versioning": "0.84.0",
    "@typespec/openapi": "1.14.0",
    "@typespec/xml": "0.84.0",
    "@typespec/events": "0.84.0",
    "@typespec/sse": "0.84.0",
    "@typespec/streams": "0.84.0",
    "@azure-tools/typespec-azure-core": "0.70.0",
    "@azure-tools/typespec-client-generator-core": "0.70.0",
    "@azure-tools/typespec-azure-resource-manager": "0.70.0",
    "@azure-tools/typespec-autorest": "0.70.0",
    "@azure-tools/typespec-liftr-base": "0.14.0"
  },
  "private": true
}
