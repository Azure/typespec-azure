{
  "extends": "../../core/tsconfig.base.json",
  "references": [
    { "path": "../../core/packages/compiler/tsconfig.json" },
    { "path": "../../core/packages/openapi/tsconfig.json" },
    { "path": "../../core/packages/rest/tsconfig.json" },
    { "path": "../typespec-azure-resource-manager/tsconfig.build.json" }
  ],
  "compilerOptions": {
    "outDir": "dist-dev",
    "rootDir": ".",
    "tsBuildInfoFile": "temp/tsconfig.tsbuildinfo",
    "types": ["node"],
    "checkJs": true,
    "allowJs": true,
    "jsxImportSource": "@emotion/react",
    "lib": ["DOM", "ES2022"],
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "generated-defs/**/*.ts"],
  "exclude": ["**/*.test.*"]
}
